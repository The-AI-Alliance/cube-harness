# Copy this file to .env and fill in your values.
# cube-harness uses LiteLLM — any provider works.
# See: https://docs.litellm.ai/docs/providers

# OpenAI (default in hello_miniwob recipe)
OPENAI_API_KEY=

# Azure OpenAI (change model_name to "azure/gpt-4o-mini" in the recipe)
# AZURE_API_KEY=
# AZURE_API_BASE=
# AZURE_API_VERSION=

# Anthropic (change model_name to "claude-opus-4-6" in the recipe)
# ANTHROPIC_API_KEY=
