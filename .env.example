# Copy this file to .env and fill in your values.
# cube-harness uses LiteLLM — any provider works, not just Azure.
# See: https://docs.litellm.ai/docs/providers

# Azure OpenAI (default in hello_miniwob recipe)
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=

# OpenAI (change model_name to "gpt-4o" in the recipe)
# OPENAI_API_KEY=

# Anthropic (change model_name to "claude-opus-4-6" in the recipe)
# ANTHROPIC_API_KEY=
